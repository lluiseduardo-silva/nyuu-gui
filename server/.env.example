# Porta do servidor HTTP (API + UI em produção)
PORT=8787

# Diretório de dados (db SQLite, nyuu.json, logs dos jobs).
# Em dev/Windows pode deixar o default (./data dentro de server/).
# Em produção (Debian LXC) aponte para algo persistente, ex: /var/lib/nyuu-gui
# DATA_DIR=/var/lib/nyuu-gui

# Força o modo mock (simula nyuu/par2/mediainfo sem os binários).
# Por padrão liga sozinho no Windows. Use 0 para desligar, 1 para ligar.
# MOCK=1
